	$(MAKE) $(MAKESILENT) -f CMakeFiles/level_roundtrip_test.dir/build.make CMakeFiles/level_roundtrip_test.dir/tests/level_roundtrip_test.c.o
.PHONY : tests/level_roundtrip_test.c.o

tests/level_roundtrip_test.i: tests/level_roundtrip_test.c.i
.PHONY : tests/level_roundtrip_test.i

# target to preprocess a source file
tests/level_roundtrip_test.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/level_roundtrip_test.dir/build.make CMakeFiles/level_roundtrip_test.dir/tests/level_roundtrip_test.c.i
.PHONY : tests/level_roundtrip_test.c.i

tests/level_roundtrip_test.s: tests/level_roundtrip_test.c.s
.PHONY : tests/level_roundtrip_test.s

# target to generate assembly for a file
tests/level_roundtrip_test.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/level_roundtrip_test.dir/build.make CMakeFiles/level_roundtrip_test.dir/tests/level_roundtrip_test.c.s
.PHONY : tests/level_roundtrip_test.c.s

